package main

import (
	"../../kos"
	"../../ui"
)

const (
	appExitButton kos.ButtonID = 1

	appWindowX      = 420
	appWindowY      = 220
	appWindowWidth  = 360
	appWindowHeight = 150
	appWindowTitle  = "__WINDOW_TITLE__"
)

func main() {
	for {
		switch kos.WaitEvent() {
		case kos.EventRedraw:
			redraw()
		case kos.EventButton:
			if kos.CurrentButtonID() == appExitButton {
				kos.Exit()
				return
			}
		}
	}
}

func redraw() {
	kos.BeginRedraw()
	kos.OpenWindow(appWindowX, appWindowY, appWindowWidth, appWindowHeight, appWindowTitle)
	kos.DrawText(28, 52, ui.White, "__WINDOW_TITLE__")
	kos.DrawText(28, 78, ui.Silver, "__PROGRAM__ scaffolded from templates/basic-app")
	kos.EndRedraw()
}
